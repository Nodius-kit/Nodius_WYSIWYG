{
  "name": "@nodius/editor",
  "version": "0.1.0",
  "type": "module",
  "description": "Zero-dependency WYSIWYG editor framework — plugin-based, collaboration-ready",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:stress": "vitest run tests/stress",
    "typecheck": "tsc --noEmit",
    "playground": "vite --config playground/vite.config.ts"
  },
  "dependencies": {
    "@nodius/utils": "^1.1.2"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "license": "MIT"
}
